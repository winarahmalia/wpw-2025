<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HOTEL DE LUNA - Luxury Stay</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #2c2c2c;
      --accent: #d4a373; /* Gold/Bronze */
      --bg-cream: #fdfaf5;
      --white: #ffffff;
      --text-muted: #666;
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      margin: 0;
      background-color: var(--bg-cream);
      color: var(--primary);
      line-height: 1.6;
    }

    /* --- Header & Nav --- */
    header {
      background-color: var(--white);
      padding: 20px 50px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      letter-spacing: 2px;
      color: var(--primary);
    }

    nav a {
      margin: 0 15px;
      text-decoration: none;
      color: var(--primary);
      font-weight: 400;
      font-size: 14px;
      transition: 0.3s;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    nav a:hover { color: var(--accent); }

    /* --- Hero/Title Section --- */
    .rooms-title {
      font-family: 'Playfair Display', serif;
      text-align: center;
      margin: 60px 0 40px;
      font-size: 42px;
    }

    .rooms-title::after {
      content: '';
      display: block;
      width: 50px;
      height: 3px;
      background: var(--accent);
      margin: 15px auto;
    }

    /* --- Room Grid & Cards --- */
    .room-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 30px;
      padding: 0 50px 80px;
    }

    .room-card {
      background: var(--white);
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.03);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      display: flex;
      flex-direction: column;
    }

    .room-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .room-card img {
      width: 100%;
      height: 240px;
      object-fit: cover;
    }

    .room-content { padding: 25px; text-align: left; }

    .room-card h3 {
      font-family: 'Playfair Display', serif;
      margin: 0 0 10px;
      font-size: 22px;
    }

    .price {
      color: var(--accent);
      font-weight: 600;
      font-size: 20px;
      margin-bottom: 15px;
    }

    .room-specs {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 20px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .status {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 20px;
    }
    .available { color: #27ae60; }
    .booked { color: #e74c3c; }

    .btn {
      display: block;
      text-align: center;
      padding: 12px;
      background: var(--primary);
      color: var(--white);
      text-decoration: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      transition: 0.3s;
    }

    .btn:hover { background: var(--accent); color: var(--white); }

    .btn:disabled { background: #ddd; cursor: not-allowed; }

    /* --- About Us Section --- */
    .about-section {
      text-align: center;
      padding: 100px 20px;
      background-color: var(--white);
    }

    .about-section h2 {
      font-family: 'Playfair Display', serif;
      font-size: 38px;
    }

    .about-section p {
      font-size: 16px;
      max-width: 700px;
      margin: 0 auto 50px;
      color: var(--text-muted);
    }

    .circle-gallery {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .circle-gallery img {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--bg-cream);
      transition: 0.3s;
    }

    .circle-gallery img:hover { transform: scale(1.1); border-color: var(--accent); }

    /* --- Gallery Section --- */
    .gallery-section { padding: 80px 50px; }
    .gallery-section h3 { font-family: 'Playfair Display', serif; text-align: center; font-size: 32px; margin-bottom: 40px;}

    .square-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .square-gallery img {
      width: 100%;
      height: 250px;
      border-radius: 12px;
      object-fit: cover;
      transition: 0.4s;
    }

    .square-gallery img:hover { filter: brightness(70%); }

    /* --- Footer --- */
    footer {
      background: #1a1a1a;
      color: #ccc;
      padding: 80px 50px 30px;
      font-size: 14px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 50px;
      max-width: 1200px;
      margin: 0 auto 50px;
      text-align: left;
    }

    footer h4 { color: var(--white); font-family: 'Playfair Display', serif; font-size: 20px; margin-bottom: 20px;}

    .newsletter-input {
      padding: 12px;
      width: 100%;
      border: none;
      border-radius: 5px;
      margin-bottom: 10px;
    }

    /* --- Hamburger --- */
    .hamburger { display: none; flex-direction: column; cursor: pointer; }
    .hamburger span { height: 2px; width: 25px; background: var(--primary); margin: 3px 0; }

    @media (max-width: 768px) {
      .hamburger { display: flex; }
      nav {
        display: none;
        position: absolute;
        top: 70px; right: 50px;
        background: white;
        flex-direction: column;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
      }
      nav.show { display: flex; }
      .footer-grid { grid-template-columns: 1fr; text-align: center; }
    }
  </style>
</head>
<body>

<header>
  <div class="logo">HOTEL DE LUNA</div>
  <div class="hamburger" onclick="toggleMenu()">
    <span></span><span></span><span></span>
  </div>
  <nav id="navMenu">
    <a href="/booking/homepage">Home</a>
    <a href="#rooms-section">Rooms</a>
    <a href="#about-section">About</a>
    <a href="/booking/my-bookings">My Bookings</a> 
    <a href="/user/profile">Profile</a>
    <a href="/logout" style="color: #e74c3c;">Logout</a>
  </nav>
</header>

<h2 class="rooms-title" id="rooms-section">Our Luxury Rooms</h2>

<div class="room-grid">
  <% rooms.forEach(room => { %>
    <div class="room-card">
      <img src="/img/foto 2.jpg" alt="Luxury Room">
      <div class="room-content">
        <h3><%= room.name %></h3>
        <p class="price">$<%= room.price %> <span style="font-size: 12px; color: #999;">/ Night</span></p>
        
        <div class="room-specs">
          <span>📏 <%= room.size %> ft</span>
          <span>👤 Max <%= room.capacity %> Pers.</span>
          <span>🛏️ <%= room.bed %></span>
          <span>✨ <%= room.services %></span>
        </div>
        
        <% if (room.status === 'booked') { %>
          <p class="status booked">● Fully Booked</p>
          <button class="btn" disabled>Unavailable</button>
        <% } else { %>
          <p class="status available">● Available Now</p>
          <a class="btn" href="/booking/form?roomId=<%= room.id %>">Book Room</a>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<div class="about-section" id="about-section">
  <h2>About Our Legacy</h2>
  <p>
    Since 1910, Hotel De Luna has defined luxury in the heart of Paris. 
    Combining Belle Époque elegance with modern sophistication, we offer an 
    unparalleled experience for the discerning traveler.
  </p>
  <div class="circle-gallery">
    <img src="/img/foto1.jpg" alt="Lobby">
    <img src="/img/foto2.jpg" alt="Suite">
    <img src="/img/foto3.jpg" alt="Dining">
    <img src="/img/foto4.jpg" alt="Spa">
  </div>
</div>

<div class="gallery-section">
  <h3>Curated Moments</h3>
  <div class="square-gallery">
    <img src="/img/page 1.jpg" alt="1">
    <img src="/img/page 2.jpg" alt="2">
    <img src="/img/page 3.jpg" alt="3">
    <img src="/img/page 4.jpg" alt="4">
    <img src="/img/page 5.jpg" alt="5">
  </div>
</div>

<footer>
  <div class="footer-grid">
    <div>
      <h4>HOTEL DE LUNA</h4>
      <p>Luxury and comfort redefined for the modern age. Experience Paris like never before.</p>
    </div>
    <div>
      <h4>Quick Contact</h4>
      <p>📞 +23 345 67890<br>✉️ hoteldeluna@gmail.com</p>
    </div>
    <div>
      <h4>Newsletter</h4>
      <input type="email" placeholder="Your Email Address" class="newsletter-input">
      <button class="btn" style="background: var(--accent);">Subscribe</button>
    </div>
  </div>
  <hr style="border: 0; border-top: 1px solid #333; margin-bottom: 20px;">
  &copy; 2026 HOTEL DE LUNA. Crafted with Elegance.
</footer>

<script>
  function toggleMenu() {
    document.getElementById('navMenu').classList.toggle('show');
  }
</script>
</body>
</html>